<!DOCTYPE html>
<html lang="fr" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>THOT — Tri et Organisation</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Barlow+Condensed:wght@300;400;600;700&family=Barlow:wght@300;400;500&display=swap');
  :root[data-theme="dark"]{--bg:#0a0c10;--surface:#0f1318;--surface2:#161b22;--border:#21262d;--border-active:#30363d;--accent:#58a6ff;--accent2:#3fb950;--warn:#d29922;--danger:#f85149;--text:#e6edf3;--text-muted:#7d8590;--text-dim:#484f58;}
  :root[data-theme="light"]{--bg:#f6f8fa;--surface:#ffffff;--surface2:#f0f2f5;--border:#d0d7de;--border-active:#b0b7be;--accent:#0969da;--accent2:#1a7f37;--warn:#9a6700;--danger:#cf222e;--text:#1f2328;--text-muted:#656d76;--text-dim:#adb5bd;}
  *{box-sizing:border-box;margin:0;padding:0;}
  body{background:var(--bg);color:var(--text);font-family:"Barlow",sans-serif;font-size:14px;min-height:100vh;transition:background .2s,color .2s;}
  header{display:flex;align-items:center;gap:16px;padding:0 24px;height:56px;background:var(--surface);border-bottom:1px solid var(--border);}
  .logo{font-family:"Barlow Condensed",sans-serif;font-weight:700;font-size:22px;letter-spacing:4px;color:var(--accent);text-transform:uppercase;}
  .logo span{color:var(--text-muted);font-weight:300;font-size:13px;letter-spacing:2px;margin-left:8px;}
  .theme-btn{margin-left:auto;background:none;border:1px solid var(--border);border-radius:6px;padding:4px 8px;cursor:pointer;font-size:16px;color:var(--text-muted);}
  .theme-btn:hover{border-color:var(--accent);color:var(--accent);}
  .container{max-width:900px;margin:0 auto;padding:32px 24px;}
  .card{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:24px;margin-bottom:20px;}
  .card h2{font-family:"Barlow Condensed",sans-serif;font-size:16px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:var(--text-muted);margin-bottom:16px;}
  .drop-zone{border:2px dashed var(--border);border-radius:8px;padding:40px;text-align:center;cursor:pointer;transition:all .2s;font-family:"Share Tech Mono",monospace;font-size:13px;color:var(--text-muted);}
  .drop-zone:hover,.drop-zone.drag-over{border-color:var(--accent);color:var(--accent);background:rgba(88,166,255,.05);}
  .drop-zone .icon{font-size:48px;margin-bottom:12px;opacity:.4;}
  .btn{display:inline-flex;align-items:center;justify-content:center;gap:6px;padding:10px 20px;border-radius:4px;border:1px solid var(--border);background:var(--surface2);color:var(--text);font-family:"Barlow Condensed",sans-serif;font-size:13px;font-weight:600;letter-spacing:1px;cursor:pointer;transition:all .15s;text-transform:uppercase;}
  .btn:hover:not(:disabled){border-color:var(--accent);color:var(--accent);}
  .btn:disabled{opacity:.3;cursor:not-allowed;}
  .btn-primary{background:var(--accent);color:#fff;border-color:var(--accent);}
  .btn-primary:hover:not(:disabled){opacity:.85;color:#fff;}
  .btn-success{background:var(--accent2);color:#fff;border-color:var(--accent2);}
  .btn-success:hover:not(:disabled){opacity:.85;color:#fff;}
  .btn-row{display:flex;gap:10px;margin-top:16px;flex-wrap:wrap;}
  .stats-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:10px;margin-bottom:16px;}
  .stat-card{background:var(--surface2);border:1px solid var(--border);border-radius:6px;padding:12px 16px;}
  .stat-card .val{font-family:"Share Tech Mono",monospace;font-size:22px;font-weight:700;color:var(--accent);}
  .stat-card .lbl{font-size:11px;color:var(--text-muted);font-family:"Share Tech Mono",monospace;margin-top:2px;}
  .tree{font-family:"Share Tech Mono",monospace;font-size:12px;line-height:1.8;max-height:400px;overflow-y:auto;background:var(--bg);border:1px solid var(--border);border-radius:6px;padding:16px;}
  .tree .folder{color:var(--accent);font-weight:700;}
  .tree .sub{color:var(--warn);}
  .tree .corps{color:var(--danger);}
  .tree .file{color:var(--text-muted);}
  .tree .count{color:var(--accent2);}
  .progress{height:4px;background:var(--border);border-radius:2px;overflow:hidden;margin:12px 0;}
  .progress-fill{height:100%;background:var(--accent);width:0%;transition:width .3s;border-radius:2px;}
  .progress-fill.indeterminate{width:30%!important;animation:indeterminate 1.5s infinite;}
  @keyframes indeterminate{0%{margin-left:-30%}100%{margin-left:100%}}
  .prog-lbl{font-family:"Share Tech Mono",monospace;font-size:11px;color:var(--text-muted);}
  .badge{font-family:"Share Tech Mono",monospace;font-size:10px;padding:2px 6px;border-radius:3px;font-weight:600;display:inline-block;}
  .bc{background:rgba(63,185,80,.15);color:var(--accent2);border:1px solid rgba(63,185,80,.3);}
  .bb{background:rgba(88,166,255,.15);color:var(--accent);border:1px solid rgba(88,166,255,.3);}
  .bd{background:rgba(248,81,73,.15);color:var(--danger);border:1px solid rgba(248,81,73,.3);}
  .bw{background:rgba(210,153,34,.15);color:var(--warn);border:1px solid rgba(210,153,34,.3);}
  .alert{padding:10px 14px;border-radius:6px;font-family:"Share Tech Mono",monospace;font-size:11px;margin-bottom:12px;}
  .alert-warn{background:rgba(210,153,34,.1);border:1px solid rgba(210,153,34,.3);color:var(--warn);}
  .alert-ok{background:rgba(63,185,80,.1);border:1px solid rgba(63,185,80,.3);color:var(--accent2);}
  .alert-err{background:rgba(248,81,73,.1);border:1px solid rgba(248,81,73,.3);color:var(--danger);}
  .log{font-family:"Share Tech Mono",monospace;font-size:10px;color:var(--text-dim);max-height:120px;overflow-y:auto;background:var(--bg);border:1px solid var(--border);border-radius:6px;padding:10px;margin-top:12px;line-height:1.7;}
  .log .ok{color:var(--accent2);}
  .log .err{color:var(--danger);}
  .log .warn{color:var(--warn);}
  .log .info{color:var(--accent);}
  ::-webkit-scrollbar{width:5px;}::-webkit-scrollbar-track{background:var(--bg);}::-webkit-scrollbar-thumb{background:var(--border-active);border-radius:3px;}

  /* Mode sombre pour la zone de dépôt de fichiers */
  input[type=file]{display:none;}
</style>
</head>
<body>
<header>
  <div class="logo">THOT <span>// TRI ET ORGANISATION</span></div>
  <button class="theme-btn" id="themeBtn">&#9790;</button>
</header>

<div class="container">

  <!-- ÉTAPE 1 : Sélection des fichiers -->
  <div class="card">
    <h2>&#9312; Selectionner les fichiers a trier</h2>
    <div class="alert alert-warn" id="compatAlert">
      &#9888; Necessite Chrome ou Edge (API File System Access). Firefox supporte uniquement la lecture, pas l'ecriture dans les dossiers.
    </div>
    <div class="drop-zone" id="dropZone">
      <div class="icon">&#128230;</div>
      <div>Glisse tes fichiers SVG/PNG ici<br>ou clique pour selectionner</div>
      <div style="margin-top:8px;font-size:10px;opacity:.6">Selectionne tous les fichiers du ZIP extrait (Ctrl+A dans le dossier)</div>
    </div>
    <input type="file" id="fileInput" multiple accept=".svg,.png">
    <div class="btn-row">
      <button class="btn btn-primary" id="selectFilesBtn">&#128193; Choisir les fichiers</button>
      <button class="btn" id="clearBtn" disabled>&#128465; Effacer</button>
    </div>
  </div>

  <!-- STATS après chargement -->
  <div class="card" id="statsCard" style="display:none">
    <h2>&#9313; Apercu de l'organisation</h2>
    <div class="stats-grid" id="statsGrid"></div>
    <div id="treeContainer" class="tree"></div>
    <div class="btn-row">
      <button class="btn btn-success" id="sortBtn">&#10003; Trier et telecharger en ZIP</button>
    </div>
    <div class="progress" id="progBar" style="display:none">
      <div class="progress-fill" id="progFill"></div>
    </div>
    <div class="prog-lbl" id="progLbl"></div>
    <div class="log" id="logEl"></div>
  </div>

  <!-- RÉSULTAT -->
  <div class="card" id="resultCard" style="display:none">
    <h2>&#9314; Resultat</h2>
    <div id="resultContent"></div>
  </div>

</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
<script>
var files = [];
var parsedFiles = [];
var currentTheme = "dark";

// ── THEME ────────────────────────────────────────────────────────────────────
document.getElementById("themeBtn").addEventListener("click", function() {
  currentTheme = currentTheme === "dark" ? "light" : "dark";
  document.documentElement.setAttribute("data-theme", currentTheme);
  document.getElementById("themeBtn").innerHTML = currentTheme === "dark" ? "&#9790;" : "&#9788;";
});

// Verifier compatibilite navigateur
if (!window.showOpenFilePicker && !window.FileReader) {
  document.getElementById("compatAlert").innerHTML = "&#10007; Navigateur non compatible. Utilise Chrome, Edge ou Firefox.";
  document.getElementById("compatAlert").className = "alert alert-err";
} else {
  document.getElementById("compatAlert").innerHTML = "&#10003; Navigateur compatible — glisse tes fichiers ou clique le bouton.";
  document.getElementById("compatAlert").className = "alert alert-ok";
}

// ── PARSING DU NOM DE FICHIER ─────────────────────────────────────────────────
// Formats supportes :
// PAYS_BRANCHE_GRADE_Nom.ext          (standard)
// PAYS_BRANCHE_CORPS_GRADE_Nom.ext    (avec corps ex: IRGC)
function parseFileName(name) {
  // Retirer extension
  var base = name.replace(/\.(svg|png)$/i, "");
  var parts = base.split("_");
  if (parts.length < 4) return null;

  var country = parts[0];
  var branch  = parts[1];

  // Detecter si le 3e segment est un corps (pas un code OF/OR)
  var gradePattern = /^(OF|OR)\d+$|^OFD$/i;
  var corps = "";
  var rankIdx = 2;

  if (parts.length >= 5 && !gradePattern.test(parts[2])) {
    corps   = parts[2];
    rankIdx = 3;
  }

  var rank     = parts[rankIdx] || "";
  var gradeName = parts.slice(rankIdx + 1).join("_") || "";

  // Valider pays (3 lettres) et branche (AIR/TERRE/MER)
  if (!/^[A-Z]{2,3}$/.test(country)) return null;
  if (!/^(AIR|TERRE|MER)$/.test(branch)) return null;
  if (!gradePattern.test(rank)) return null;

  return { country: country, branch: branch, corps: corps, rank: rank, gradeName: gradeName, original: name };
}

// ── CHARGEMENT DES FICHIERS ──────────────────────────────────────────────────
function handleFiles(fileList) {
  files = Array.from(fileList).filter(function(f) {
    return /\.(svg|png)$/i.test(f.name);
  });
  parsedFiles = [];
  var skipped = 0;
  files.forEach(function(f) {
    var parsed = parseFileName(f.name);
    if (parsed) {
      parsed.fileObj = f;
      parsedFiles.push(parsed);
    } else {
      skipped++;
    }
  });
  if (parsedFiles.length === 0) {
    logMsg("Aucun fichier avec nomenclature THOT reconnu. Verifie que les fichiers sont au format PAYS_BRANCHE_GRADE_Nom.svg", "err");
    return;
  }
  logMsg("Charge: " + parsedFiles.length + " fichiers reconnus" + (skipped > 0 ? ", " + skipped + " ignores" : ""), "ok");
  document.getElementById("clearBtn").disabled = false;
  buildPreview();
  document.getElementById("statsCard").style.display = "block";
}

document.getElementById("dropZone").addEventListener("click", function() {
  document.getElementById("fileInput").click();
});
document.getElementById("selectFilesBtn").addEventListener("click", function() {
  document.getElementById("fileInput").click();
});
document.getElementById("fileInput").addEventListener("change", function(e) {
  handleFiles(e.target.files);
});

// Drag & drop
var dz = document.getElementById("dropZone");
dz.addEventListener("dragover", function(e) { e.preventDefault(); dz.classList.add("drag-over"); });
dz.addEventListener("dragleave", function() { dz.classList.remove("drag-over"); });
dz.addEventListener("drop", function(e) {
  e.preventDefault();
  dz.classList.remove("drag-over");
  handleFiles(e.dataTransfer.files);
});

// ── CONSTRUCTION DE L'APERÇU ─────────────────────────────────────────────────
function buildPreview() {
  // Construire la structure arborescente
  var tree = {};
  var totalCountries = {};
  var totalBranches  = {};
  var totalCorps     = {};

  parsedFiles.forEach(function(f) {
    if (!tree[f.country]) tree[f.country] = {};
    var branchKey = f.corps ? f.branch + "_" + f.corps : f.branch;
    if (!tree[f.country][branchKey]) tree[f.country][branchKey] = [];
    tree[f.country][branchKey].push(f);
    totalCountries[f.country] = true;
    totalBranches[f.branch]   = true;
    if (f.corps) totalCorps[f.corps] = true;
  });

  // Stats
  var statsGrid = document.getElementById("statsGrid");
  statsGrid.innerHTML =
    statCard(parsedFiles.length, "Fichiers") +
    statCard(Object.keys(totalCountries).length, "Pays") +
    statCard(Object.keys(totalBranches).length, "Branches") +
    (Object.keys(totalCorps).length > 0 ? statCard(Object.keys(totalCorps).length, "Corps speciaux") : "");

  // Arbre
  var treeHtml = "";
  var countries = Object.keys(tree).sort();
  countries.forEach(function(country) {
    var branches = Object.keys(tree[country]).sort();
    var countryTotal = 0;
    branches.forEach(function(b) { countryTotal += tree[country][b].length; });
    treeHtml += "<div><span class='folder'>&#128193; " + country + "/</span> <span class='count'>(" + countryTotal + " fichiers)</span></div>";
    branches.forEach(function(branchKey) {
      var count = tree[country][branchKey].length;
      var isCorps = branchKey.indexOf("_") !== -1;
      if (isCorps) {
        var parts = branchKey.split("_");
        treeHtml += "<div style='margin-left:20px'><span class='sub'>&#128193; " + parts[0] + "/</span></div>";
        treeHtml += "<div style='margin-left:40px'><span class='corps'>&#128193; " + parts[1] + "/</span> <span class='count'>(" + count + ")</span></div>";
      } else {
        treeHtml += "<div style='margin-left:20px'><span class='sub'>&#128193; " + branchKey + "/</span> <span class='count'>(" + count + ")</span></div>";
      }
      // Montrer les 3 premiers fichiers comme exemple
      var examples = tree[country][branchKey].slice(0, 3);
      examples.forEach(function(f) {
        treeHtml += "<div style='margin-left:" + (isCorps ? 60 : 40) + "px'><span class='file'>&#128441; " + f.original + "</span></div>";
      });
      if (count > 3) {
        treeHtml += "<div style='margin-left:" + (isCorps ? 60 : 40) + "px'><span class='file' style='opacity:.5'>... et " + (count - 3) + " autres</span></div>";
      }
    });
  });
  document.getElementById("treeContainer").innerHTML = treeHtml;
}

function statCard(val, lbl) {
  return "<div class='stat-card'><div class='val'>" + val + "</div><div class='lbl'>" + lbl + "</div></div>";
}

// ── TRI ET GÉNÉRATION DU ZIP ──────────────────────────────────────────────────
document.getElementById("sortBtn").addEventListener("click", sortAndZip);

async function sortAndZip() {
  if (!parsedFiles.length) return;
  document.getElementById("sortBtn").disabled = true;
  document.getElementById("progBar").style.display = "block";
  document.getElementById("progFill").className = "progress-fill indeterminate";
  document.getElementById("progLbl").textContent = "Lecture des fichiers...";
  logMsg("Debut du tri de " + parsedFiles.length + " fichiers...", "info");

  var zip = new JSZip();
  var done = 0;
  var errors = 0;

  for (var i = 0; i < parsedFiles.length; i++) {
    var f = parsedFiles[i];
    try {
      var buf = await readFileAsArrayBuffer(f.fileObj);

      // Construire le chemin dans le ZIP
      // Structure : PAYS/BRANCHE/fichier.svg
      //         ou : PAYS/BRANCHE/CORPS/fichier.svg
      var zipPath;
      if (f.corps) {
        zipPath = f.country + "/" + f.branch + "/" + f.corps + "/" + f.original;
      } else {
        zipPath = f.country + "/" + f.branch + "/" + f.original;
      }

      zip.file(zipPath, buf);
      done++;

      var pct = Math.round((i + 1) / parsedFiles.length * 100);
      document.getElementById("progFill").className = "progress-fill";
      document.getElementById("progFill").style.width = pct + "%";
      document.getElementById("progLbl").textContent = (i + 1) + " / " + parsedFiles.length + " — " + f.original;

      if (i % 20 === 0) logMsg("Traite " + (i + 1) + "/" + parsedFiles.length, "ok");

    } catch(err) {
      errors++;
      logMsg("ERR " + f.original + ": " + err.message, "err");
    }
  }

  logMsg("Lecture terminee. Generation ZIP...", "info");
  document.getElementById("progFill").className = "progress-fill indeterminate";
  document.getElementById("progLbl").textContent = "Generation ZIP...";

  try {
    var content = await zip.generateAsync(
      { type: "blob", compression: "DEFLATE", compressionOptions: { level: 6 } },
      function(meta) {
        document.getElementById("progLbl").textContent = "ZIP " + meta.percent.toFixed(0) + "%";
      }
    );

    // Telecharger le ZIP
    var a = document.createElement("a");
    a.href = URL.createObjectURL(content);
    a.download = "THOT_TRIE_" + new Date().toISOString().slice(0, 10) + ".zip";
    a.click();
    URL.revokeObjectURL(a.href);

    document.getElementById("progFill").className = "progress-fill";
    document.getElementById("progFill").style.width = "100%";
    document.getElementById("progLbl").textContent = "Termine — " + done + " fichiers tries";
    logMsg("ZIP telecharge avec succes: " + done + " fichiers, " + errors + " erreurs", "ok");

    showResult(done, errors, zip);

  } catch(zipErr) {
    logMsg("Erreur generation ZIP: " + zipErr.message, "err");
  }

  document.getElementById("sortBtn").disabled = false;
}

function readFileAsArrayBuffer(file) {
  return new Promise(function(resolve, reject) {
    var reader = new FileReader();
    reader.onload = function(e) { resolve(e.target.result); };
    reader.onerror = function() { reject(new Error("Lecture impossible")); };
    reader.readAsArrayBuffer(file);
  });
}

function showResult(done, errors, zip) {
  var resultCard = document.getElementById("resultCard");
  var resultContent = document.getElementById("resultContent");
  resultCard.style.display = "block";

  // Construire le resume de l'arborescence finale
  var structure = {};
  parsedFiles.forEach(function(f) {
    var country = f.country;
    var folder  = f.corps ? f.branch + "/" + f.corps : f.branch;
    if (!structure[country]) structure[country] = {};
    if (!structure[country][folder]) structure[country][folder] = 0;
    structure[country][folder]++;
  });

  var html = "<div class='alert " + (errors === 0 ? "alert-ok" : "alert-warn") + "'>";
  html += "&#10003; " + done + " fichiers tries en " + Object.keys(structure).length + " pays";
  if (errors > 0) html += " — " + errors + " erreurs";
  html += "</div>";

  html += "<div class='tree'>";
  html += "<div style='margin-bottom:8px;color:var(--text-muted);font-size:11px'>Structure du ZIP telecharge :</div>";
  Object.keys(structure).sort().forEach(function(country) {
    html += "<div><span class='folder'>&#128193; " + country + "/</span></div>";
    Object.keys(structure[country]).sort().forEach(function(folder) {
      var count = structure[country][folder];
      var parts = folder.split("/");
      if (parts.length === 2) {
        html += "<div style='margin-left:20px'><span class='sub'>&#128193; " + parts[0] + "/</span></div>";
        html += "<div style='margin-left:40px'><span class='corps'>&#128193; " + parts[1] + "/</span> <span class='count'>(" + count + " fichiers)</span></div>";
      } else {
        html += "<div style='margin-left:20px'><span class='sub'>&#128193; " + folder + "/</span> <span class='count'>(" + count + " fichiers)</span></div>";
      }
    });
  });
  html += "</div>";

  html += "<div class='btn-row' style='margin-top:16px'>";
  html += "<button class='btn btn-primary' onclick='window.location.reload()'>&#8635; Nouveau tri</button>";
  html += "</div>";

  resultContent.innerHTML = html;
  resultCard.scrollIntoView({ behavior: "smooth" });
}

// ── CLEAR ────────────────────────────────────────────────────────────────────
document.getElementById("clearBtn").addEventListener("click", function() {
  files = [];
  parsedFiles = [];
  document.getElementById("fileInput").value = "";
  document.getElementById("statsCard").style.display = "none";
  document.getElementById("resultCard").style.display = "none";
  document.getElementById("clearBtn").disabled = true;
  document.getElementById("logEl").innerHTML = "";
  logMsg("Reinitialise", "warn");
});

// ── LOG ──────────────────────────────────────────────────────────────────────
function logMsg(msg, type) {
  type = type || "";
  var d = document.createElement("div");
  d.className = type;
  d.textContent = "[" + new Date().toLocaleTimeString("fr-FR") + "] " + msg;
  var logEl = document.getElementById("logEl");
  logEl.appendChild(d);
  logEl.scrollTop = logEl.scrollHeight;
}

logMsg("THOT Tri pret — selectionne tes fichiers SVG/PNG.", "info");
</script>
</body>
</html>
